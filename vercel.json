{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "glob": "releases/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/releases/(.*)",
      "dest": "/releases/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
